<h1>今日のワークアウト</h1>

<% unit_label = current_user.profile.unit == "lb" ? "lb" : "kg" %>

<% if @ongoing_session %>
  <div class="screen-card" style="margin-top:10px;">
    <div style="font-size:12px; color:#667085;">未完了セッション</div>
    <div style="font-weight:700; margin-top:4px;"><%= @ongoing_session.program_day&.label || "Workout" %></div>
    <%= link_to "続行", workout_session_path(@ongoing_session), style: "display:inline-block; margin-top:8px;" %>
  </div>
<% end %>

<section class="screen-card" style="margin-top:10px;">
  <h2 style="font-size:16px;">今週のサマリ</h2>
  <div style="font-size:13px; color:#475467;">実施回数: <strong><%= @weekly_completed %></strong> 回</div>

  <% if @best_weights.any? %>
    <div style="margin-top:8px; font-size:12px; color:#667085;">主要種目の最高重量</div>
    <div style="display:grid; gap:4px; margin-top:4px;">
      <% @best_weights.each do |name, weight, reps| %>
        <div>
          <%= name %>:
          <strong><%= weight.round(1) %><%= unit_label %></strong>
          <span style="font-size:12px; color:#667085;">（<%= reps %>回）</span>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<% @templates.each do |template| %>
  <section class="screen-card" style="margin-top:10px;">
    <h2 style="font-size:16px;"><%= template.name %></h2>
    <div style="display:grid; gap:10px; margin-top:8px;">
      <% template.program_days.order(:day_index).each do |day| %>
        <div style="display:flex; justify-content:space-between; align-items:center; border:1px solid #e5e7eb; border-radius:12px; padding:10px;">
          <div>
            <div style="font-weight:700;"><%= day.label %></div>
            <div style="font-size:12px; color:#667085;">種目数: <%= day.exercises.count %></div>
          </div>
          <%= button_to "開始", workout_sessions_path(program_day_id: day.id), method: :post %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
