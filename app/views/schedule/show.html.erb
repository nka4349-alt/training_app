<h1>Schedule</h1>

<% if @template.nil? %>
  <div class="screen-card">テンプレートが未作成です。</div>
<% else %>
  <p style="font-size:12px; color:#666; margin-top:-4px;">
    <%= @template.name %> を基準に、週<%= @profile.frequency_per_week %>回に合わせて次の1週間を表示しています。
  </p>

  <div class="screen-card" style="margin-top:10px;">
    <div style="display:grid; gap:8px;">
      <% @next_week.each do |item| %>
        <% weekday = %w[日 月 火 水 木 金 土][item[:date].wday] %>

        <% if item[:rest_day] %>
          <div style="display:flex; justify-content:space-between; align-items:center; border:1px solid #e5e7eb; border-radius:12px; padding:10px; background:#f8fafc;">
            <div>
              <div style="font-size:12px; color:#667085;"><%= item[:date].strftime("%m/%d") %>（<%= weekday %>）</div>
              <div style="font-weight:700; color:#667085;">休み</div>
            </div>
            <div style="font-size:12px; color:#667085;">Rest</div>
          </div>
        <% else %>
          <div style="display:flex; justify-content:space-between; align-items:center; border:1px solid #e5e7eb; border-radius:12px; padding:10px;">
            <div>
              <div style="font-size:12px; color:#667085;"><%= item[:date].strftime("%m/%d") %>（<%= weekday %>）</div>
              <div style="font-weight:700;"><%= item[:program_day].label %></div>
            </div>
            <%= button_to "開始",
                workout_sessions_path(program_day_id: item[:program_day].id),
                method: :post %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<div class="screen-card" style="margin-top:12px;">
  <h2 style="font-size:16px;">リマインド</h2>
  <p style="font-size:12px; color:#666;">頻度: 週<%= @profile.frequency_per_week %>回</p>
  <%= link_to "設定を開く", settings_path %>
</div>
