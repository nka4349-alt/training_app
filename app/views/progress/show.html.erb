<h1>Progress</h1>

<% unit_label = current_user.profile.unit == "lb" ? "lb" : "kg" %>

<section class="screen-card" style="margin-top:10px;">
  <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
    <h2 style="font-size:16px;">種目別 最高重量 推移</h2>

    <% if @exercise_options.any? %>
      <%= form_with url: progress_path, method: :get, local: true do %>
        <%= select_tag :exercise_id,
            options_for_select(@exercise_options, @selected_exercise_id),
            onchange: "this.form.submit()",
            style: "padding:8px 10px; border:1px solid #d0d5dd; border-radius:10px;" %>
      <% end %>
    <% end %>
  </div>

  <% if @selected_exercise.present? && @max_weight_points.any? %>
    <div style="margin-top:8px; font-size:12px; color:#667085;">
      <%= @selected_exercise.name %> の各セッション最高重量
    </div>

    <div style="margin-top:12px;">
      <%= max_weight_line_chart(@max_weight_points) %>
    </div>
  <% else %>
    <p style="font-size:12px; color:#667085; margin-top:8px;">表示できるデータが不足しています。</p>
  <% end %>
</section>

<section class="screen-card" style="margin-top:10px;">
  <h2 style="font-size:16px;">週ボリューム</h2>
  <% @weekly_volume.last(8).reverse_each do |week, volume| %>
    <div style="display:flex; justify-content:space-between; font-size:13px; border-top:1px solid #f2f4f7; padding:6px 0;">
      <span><%= week %></span>
      <strong><%= volume.to_i %></strong>
    </div>
  <% end %>
</section>

<section class="screen-card" style="margin-top:10px;">
  <h2 style="font-size:16px;">直近セッション</h2>

  <% @recent_sessions.each do |session| %>
    <div style="border-top:1px solid #f2f4f7; padding:10px 0;">
      <strong><%= session.finished_at.strftime("%Y-%m-%d") %></strong>
      <div style="font-size:13px; color:#667085;">
        総ボリューム: <%= session.summary["total_volume"] %>
      </div>

      <div style="display:grid; gap:8px; margin-top:8px;">
        <% session.workout_exercises.sort_by(&:order_index).each do |workout_exercise| %>
          <% summary = session_exercise_summary(workout_exercise, unit_label) %>
          <% next if summary.blank? %>

          <div style="background:#f8fafc; border:1px solid #e5e7eb; border-radius:10px; padding:8px 10px;">
            <div style="font-weight:700;"><%= workout_exercise.exercise.name %></div>
            <div style="font-size:13px; color:#475467; margin-top:6px;"><%= summary %></div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</section>
