<h1>Workout</h1>

<p style="font-size:12px; color:#666; margin-top:-4px;">現在のセッションがあれば自動で続行します。</p>

<% @templates.each do |template| %>
  <section class="screen-card" style="margin-top:10px;">
    <h2 style="font-size:16px;"><%= template.name %></h2>
    <div style="display:grid; gap:10px; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); margin-top:8px;">
      <% template.program_days.order(:day_index).each do |day| %>
        <div style="border:1px solid #e5e7eb; border-radius:12px; padding:10px;">
          <div style="font-weight:700;"><%= day.label %></div>
          <div style="font-size:12px; color:#666;">種目数: <%= day.exercises.count %></div>
          <%= button_to "開始", workout_sessions_path(program_day_id: day.id), method: :post, style: "margin-top:8px;" %>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
